<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>전주시 실시간 버스 출도착 정보</title>
    <style>
        body { font-family: 'Apple SD Gothic Neo', sans-serif; margin: 0; background-color: #f5f5f5; }
        header { background-color: white; padding: 15px; border-bottom: 1px solid #ddd; text-align: center; }
        .logo { height: 35px; }
        .main-container { padding: 20px; max-width: 500px; margin: auto; }
        h1 { font-size: 22px; margin-bottom: 20px; text-align: center; }
        
        /* 이미지 디자인 재현 */
        .search-area { background: #eee; padding: 15px; border-radius: 8px; margin-bottom: 20px; display: flex; align-items: center; justify-content: center; gap: 10px; }
        .search-box { padding: 8px; border: 1px solid #999; width: 60%; font-size: 16px; }
        .btn-search { padding: 8px 15px; background: #007bff; color: white; border: none; cursor: pointer; font-weight: bold; }

        .bus-row { display: flex; align-items: center; padding: 15px 10px; border-bottom: 1px solid #ddd; background: #fff; margin-bottom: 5px; border-radius: 5px; }
        .tag { padding: 3px 8px; border-radius: 5px; font-size: 12px; margin-right: 10px; font-weight: bold; }
        .tag-normal { background: #b2ebf2; } 
        .tag-main { background: #d1d9ff; }
        .bus-info { flex: 1; font-weight: 600; }
        .arrival-time { color: #ff4757; font-weight: bold; }
    </style>
</head>
<body>

<header>
    <img src="https://www.jeonju.go.kr/images/common/logo.png" alt="전주로고" class="logo">
</header>

<div class="main-container">
    <h1>전주시 실시간 버스 정보</h1>
    
    <div class="search-area">
        현재 버스 정류장 
        <input type="text" id="stationName" class="search-box" placeholder="정류장 이름 입력 (예: 전북대)">
        <button class="btn-search" onclick="searchStation()">조회</button>
    </div>

    <div id="result-list">
        <p style="text-align:center; color:#999;">정류장 이름을 입력하고 조회를 눌러주세요.</p>
    </div>
</div>

<script>
    const API_KEY = '23c592de0197b4416ea51da011d76c3a5e805f637ea23480fe6904b86eaf7f58';

    // 1단계: 정류소 이름으로 ID 찾기
    async function searchStation() {
        const name = document.getElementById('stationName').value;
        const resDiv = document.getElementById('result-list');
        if(!name) return alert("정류장 이름을 입력하세요!");

        resDiv.innerHTML = "정류소 찾는 중...";

        try {
            // 정류소 목록 조회 API (이름으로 검색)
            const url = `https://apis.data.go.kr/1613000/BusSttnInfoInqireService/getSttnNoList?serviceKey=${API_KEY}&cityCode=35010&nodeNm=${encodeURIComponent(name)}&_type=json`;
            const res = await fetch(url);
            const data = await res.json();
            
            if(!data.response.body.items) {
                resDiv.innerHTML = "검색 결과가 없습니다.";
                return;
            }

            // 첫 번째 검색 결과의 ID를 가져옴
            const station = Array.isArray(data.response.body.items.item) ? data.response.body.items.item[0] : data.response.body.items.item;
            getBusArrival(station.nodeid, station.nodenm);

        } catch (e) {
            resDiv.innerHTML = "정류소 검색 오류!";
        }
    }

    // 2단계: 찾은 ID로 도착 정보 가져오기
    async function getBusArrival(nodeId, nodeNm) {
        const resDiv = document.getElementById('result-list');
        const url = `https://apis.data.go.kr/1613000/ArvlInfoInqireService/getSttnAcctoArvlPrearncvsList?serviceKey=${API_KEY}&cityCode=35010&nodeId=${nodeId}&_type=json`;

        try {
            const res = await fetch(url);
            const data = await res.json();
            resDiv.innerHTML = `<h3>📍 ${nodeNm}</h3>`;

            if(!data.response.body.items) {
                resDiv.innerHTML += "운행 중인 버스가 없습니다.";
                return;
            }

            const items = Array.isArray(data.response.body.items.item) ? data.response.body.items.item : [data.response.body.items.item];
            
            items.forEach(item => {
                const isMain = item.routeno >= 3000;
                resDiv.innerHTML += `
                    <div class="bus-row">
                        <div class="tag ${isMain ? 'tag-main' : 'tag-normal'}">${isMain ? '간선' : '일반'}</div>
                        <div class="bus-info">${item.routeno}번</div>
                        <div class="arrival-time">${Math.floor(item.arrtime / 60)}분</div>
                    </div>
                `;
            });
        } catch (e) {
            resDiv.innerHTML = "도착 정보 로딩 실패!";
        }
    }
</script>

</body>
</html>
